# OpenAI — used for Whisper STT and GPT-4o conversation brain
OPENAI_API_KEY=sk-...

# ElevenLabs — used for TTS
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...

# Spontaneity engine defaults (override in persona YAML or here)
SPONTANEITY_LEVEL=2
MIN_SILENCE_BEFORE_IMPULSE=8.0
IMPULSE_PROBABILITY=0.3
MAX_IMPULSES_PER_MINUTE=4

# WebSocket server for Holobox integration
WS_HOST=0.0.0.0
WS_PORT=8765

# Research logging
LOG_DIR=logs
